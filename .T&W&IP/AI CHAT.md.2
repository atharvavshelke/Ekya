class SecureRoomAuth {
  async requestJoin(roomId) {
    const challenge = await relay.getJoinChallenge(roomId);
    
    // Derive signing key from documentKey
    const signingKey = await deriveSigningKey(documentKey);
    
    // Sign the challenge
    const signature = await sign(challenge, signingKey);
    
    // Send to relay
    await relay.verifyJoin(roomId, signature);
  }
}

// Relay verification:
// First client who joins registers their PUBLIC key
// Relay verifies signatures against this public key
// Relay NEVER sees documentKey or signing private key
But this still has the "first client captures room" problem.
