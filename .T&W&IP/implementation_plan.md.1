### 6. Developer SDK — Public API

#### [NEW] [index.js](file:///home/privateproperty/Github/Ekya/src/index.js)
Exports the public API:

```javascript
// Main classes
export { EkyaDocument } from './EkyaDocument.js';
export { EkyaProvider } from './EkyaProvider.js';

// CRDTs (for custom usage)
export { GCounter } from './core/GCounter.js';
export { LWWRegister } from './core/LWWRegister.js';
export { LWWMap } from './core/LWWMap.js';
export { RGA } from './core/RGA.js';

// Crypto utilities
export { KeyManager } from './crypto/KeyManager.js';
```

#### [NEW] [EkyaDocument.js](file:///home/privateproperty/Github/Ekya/src/EkyaDocument.js)
The main developer-facing class. Wraps a CRDT instance + crypto + sync.

```javascript
const doc = new EkyaDocument({
  id: 'my-document',
  type: 'text',        // 'text' | 'map' | 'counter'
  nodeId: 'user-abc',
});

doc.getText();              // read collaborative text
doc.insertText(5, 'hello'); // insert at position
doc.deleteText(5, 5);       // delete 5 chars from position
doc.on('update', (changes) => { ... }); // listen for remote changes
```

#### [NEW] [EkyaProvider.js](file:///home/privateproperty/Github/Ekya/src/EkyaProvider.js)
Manages network connection, encryption, and sync for one or more documents.

```javascript
const provider = new EkyaProvider({
  signalingUrl: 'ws://localhost:4444',
  documentKey: await KeyManager.generateDocumentKey(),
  transport: 'websocket',  // 'websocket' | 'webrtc' | 'both'
});

provider.connect(doc);
provider.awareness.setLocalState({ cursor: 42, user: 'Alice' });
provider.on('peers', (peers) => { ... });
```

